{
  "name": "bambu-spoolman-sync",
  "private": true,
  "version": "0.1.0-beta.10",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build && npm --workspace backend run build",
    "start": "npm --workspace backend run start",
    "test": "npm --workspace backend run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
